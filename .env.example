VITE_API_URL=http://localhost:5005/api
# Canonical auth prefix confirmed as /auth.
# Optional override only while legacy /api/auth mount still exists.
# Example legacy override: http://localhost:5005/api/auth
VITE_AUTH_URL=http://localhost:5005/auth
VITE_ENABLE_LEGACY_ERROR_TRANSLATIONS=false
VITE_BOOKINGS_QUERY_MODE=range
VITE_MAX_ALL_BOOKINGS_PAGES=50
# Keep disabled until backend ships booking pricing snapshot fields (base/taxes/discounts/total/currency).
VITE_ENABLE_BOOKING_PRICING_SNAPSHOT=false